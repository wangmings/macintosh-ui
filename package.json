{
  "name": "macintosh-ui",
  "displayName": "Macintosh UI",
  "description": "Macintosh UI brings you a unique visual experience!",
  "author": "Wang Ming",
  "publisher": "Jake",
  "icon": "icon/logo.png",
  "version": "3.5.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/wangmings/macintosh-ui.git"
  },
  "engines": {
    "vscode": "^1.87.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "configuration": {
      "title": "%plugin.name%",
      "properties": {
        "setting.ui.fontFamily": {
          "type": "string",
          "default": "Symbols Nerd Font Mono, JetBrains Mono, TsangerJinKai02-W04",
          "description": "%desc.fonts.setting%"
        },
        "default.ui.fontFamily": {
          "type": "string",
          "default": "-apple-system",
          "description": "%desc.fonts.default%",
          "enum": [
            "-apple-system",
            "SF Pro Text"
          ]
        }
      }
    },
    "commands": [
      {
        "title": "%menu.open.config%",
        "command": "menu.open.config",
        "category": "macintosh-ui"
      },
      {
        "title": "%menu.update.config%",
        "command": "menu.update.config",
        "category": "macintosh-ui"
      },
      {
        "title": "%menu.clean.config%",
        "command": "menu.clean.config",
        "category": "macintosh-ui"
      },
      {
        "title": "%menu.backup.config%",
        "command": "menu.backup.config",
        "category": "macintosh-ui"
      },
      {
        "title": "%menu.import.config%",
        "command": "menu.import.config",
        "category": "macintosh-ui"
      }
    ],
    "submenus": [
      {
        "id": "submenus-list",
        "label": "%plugin.name%"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "submenus-list",
          "group": "1_apple@1"
        }
      ],
      "submenus-list": [
        {
          "command": "menu.open.config",
          "group": "2_theme@1"
        },
        {
          "command": "menu.update.config",
          "group": "2_theme@2"
        },
        {
          "command": "menu.clean.config",
          "group": "2_theme@3"
        },
        {
          "command": "menu.backup.config",
          "group": "2_theme@4"
        }
      ]
    },
    "themes": [
      {
        "label": "Apple Zed Agola",
        "uiTheme": "vs-dark",
        "path": "vscode/themes/dark-agola.json"
      },
      {
        "label": "Apple Deep I",
        "uiTheme": "vs-dark",
        "path": "vscode/themes/dark-deep-i.json"
      },
      {
        "label": "Apple Deep II",
        "uiTheme": "vs-dark",
        "path": "vscode/themes/dark-deep-ii.json"
      },
      {
        "label": "Apple Deep III",
        "uiTheme": "vs-dark",
        "path": "vscode/themes/dark-deep-iii.json"
      },
      {
        "label": "Apple Deep IV",
        "uiTheme": "vs-dark",
        "path": "vscode/themes/dark-deep-iv.json"
      },
      {
        "label": "Apple GitHub Dark",
        "uiTheme": "vs-dark",
        "path": "vscode/themes/dark-github.json"
      },
      {
        "label": "Apple Material Dark",
        "uiTheme": "vs-dark",
        "path": "vscode/themes/dark-material.json"
      },
      {
        "label": "Apple One Dark Pro",
        "uiTheme": "vs-dark",
        "path": "vscode/themes/dark-one.json"
      },
      {
        "label": "Apple Zed Andromeda",
        "uiTheme": "vs-dark",
        "path": "vscode/themes/dark-zed.json"
      },
      {
        "label": "Apple Boxy Yesterday",
        "uiTheme": "vs",
        "path": "vscode/themes/light-boxy.json"
      },
      {
        "label": "Apple Zed Italic",
        "uiTheme": "vs",
        "path": "vscode/themes/light-italic.json"
      },
      {
        "label": "Apple Quiet VSC",
        "uiTheme": "vs",
        "path": "vscode/themes/light-quiet.json"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "pnpm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.87.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.34.0"
  },
