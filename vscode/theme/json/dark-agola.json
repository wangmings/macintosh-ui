{
  "name": "Zed Agola",
  "type": "dark",
  "semanticTokenColors": {
    "variable.declaration": {},
    "variable.defaultLibrary": {
      "foreground": "#F6CE59"
    }
  },
  "tokenColors": [
    {
      "name": "Comment: 注释",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#808080"
      },
      "scope": [
        "comment",
        "comment.source.cmake",
        "punctuation.definition.comment"
      ]
    },
    {
      "name": "Variable: 变量",
      "settings": {
        "foreground": "#F7F7F7"
      },
      "scope": [
        "source",
        "variable",
        "meta.block.c",
        "meta.block.objcpp",
        "meta.object-literal",
        "meta.function-call.c",
        "variable.other.constant",
        "meta.function-call.objc",
        "storage.modifier.import.java",
        "entity.name.function.preprocessor.c"
      ]
    },
    {
      "name": "Basic: 基本类型",
      "scope": [
        "constant.language",
        "variable.language.applescript"
      ],
      "settings": {
        "foreground": "#F266AB"
      }
    },
    {
      "name": "Storage: 变量类型",
      "settings": {
        "foreground": "#F2F013"
      },
      "scope": [
        "storage.type",
        "entity.name.type.cpp",
        "storage.modifier.objcpp",
        "meta.argument-type.objc",
        "support.type.quartz.objc",
        "support.type.property-name",
        "entity.name.type.parameter.cpp",
        "meta.body.function.definition.cpp",
        "keyword.control.def.set.applescript",
        "keyword.other.declaration-specifier.swift"
      ]
    },
    {
      "name": "Keyword: 关键字",
      "settings": {
        "foreground": "#5FDAFF"
      },
      "scope": [
        "keyword",
        "storage.modifier",
        "storage.type.class",
        "constant.other.php",
        "entity.name.tag.css",
        "entity.name.tag.html",
        "entity.name.tag.yaml",
        "support.function.lua",
        "storage.type.function",
        "support.function.swift",
        "entity.name.type.kotlin",
        "entity.scope.name.objcpp",
        "support.class.cocoa.objcpp",
        "storage.type.function.arrow",
        "support.function.print.groovy",
        "entity.name.tag.localname.xml",
        "constant.other.text.applescript",
        "support.type.property-name.json",
        "keyword.control.tell.applescript",
        "keyword.control.function.applescript",
        "punctuation.definition.variable.ruby",
        "keyword.control.def.global.applescript",
        "constant.other.miscellaneous.applescript",
        "support.function.built-in.command.applescript",
        "support.function.system-events.processes.applescript"
      ]
    },
    {
      "name": "Number: 数字",
      "settings": {
        "fontStyle": "",
        "foreground": "#BBEE78"
      },
      "scope": [
        "constant.numeric",
        "meta.parameter-expansion"
      ]
    },
    {
      "name": "String: 字符串",
      "settings": {
        "foreground": "#F6CE59"
      },
      "scope": [
        "string",
        "constant.character.escape.applescript"
      ]
    },
    {
      "name": "Control: 控制流",
      "settings": {
        "foreground": "#FF7E67"
      },
      "scope": [
        "keyword.control",
        "keyword.operator.logical",
        "keyword.operator.expression",
        "punctuation.separator.statement.and"
      ]
    },
    {
      "name": "Class_Name: 类名",
      "settings": {
        "foreground": "#FFD96A"
      },
      "scope": [
        "support.class.promise",
        "entity.name.type.class",
        "entity.name.type.objcpp",
        "support.class.built-in.applescript"
      ]
    },
    {
      "name": "Class_Inherit: 类继承",
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#FDFF00",
        "fontStyle": "  bold"
      }
    },
    {
      "name": "Function_Name: 函数名",
      "settings": {
        "foreground": "#85EF47"
      },
      "scope": [
        "meta.method.groovy",
        "entity.name.function",
        "support.function.builtin",
        "support.function.misc.css",
        "support.function.math.php",
        "support.function.gradient.css",
        "support.function.cocoa.objcpp",
        "support.function.datetime.php",
        "support.function.transform.css",
        "support.function.construct.php"
      ]
    },
    {
      "name": "Function_Argument: 函数参数",
      "settings": {
        "foreground": "#F7F7F7",
        "fontStyle": " bold"
      },
      "scope": [
        "variable.parameter",
        "variable.parameter.function.language.special.self.python"
      ]
    },
    {
      "name": "Function_Object: 默认对象",
      "settings": {
        "foreground": "#C3F8FF"
      },
      "scope": [
        "keyword.operator.new",
        "variable.language.this",
        "variable.language.special",
        "entity.other.attribute-name"
      ]
    },
    {
      "name": "Library_Object: 内置对象",
      "scope": [
        "variable.other.object",
        "variable.language.objc",
        "meta.function-call.generic.python",
        "variable.other.constant.object.js",
        "meta.function.definition.parameters.c"
      ],
      "settings": {
        "foreground": "#74F9FF"
      }
    },
    {
      "name": "Variable_Call: 变量调用",
      "scope": [
        "meta.attribute.python",
        "support.variable.swift",
        "variable.other.property.js",
        "entity.other.attribute.lua",
        "variable.other.member.objc"
      ],
      "settings": {
        "foreground": "#9EFCB4"
      }
    },
    {
      "name": "Operator: 运算符",
      "settings": {
        "foreground": "#F5A255"
      },
      "scope": [
        "keyword.operator",
        "constant.other.placeholder.c"
      ]
    },
    {
      "name": "Special: 运算符${}",
      "scope": [
        "punctuation.definition.template-expression",
        "constant.character.format.placeholder.other.python"
      ],
      "settings": {
        "foreground": "#FFC18E"
      }
    },
    {
      "name": "Bracket: 括号",
      "scope": [
        "meta.brace",
        "punctuation.shell",
        "punctuation.definition",
        "punctuation.section.block",
        "punctuation.section.parens",
        "punctuation.section.arguments",
        "punctuation.section.parameters",
        "punctuation.section.arithmetic.shell",
        "punctuation.section.group.applescript"
      ],
      "settings": {
        "foreground": "#E3F8FF"
      }
    },
    {
      "name": "Bracket: 括号()",
      "scope": [
        "meta.brace.round"
      ],
      "settings": {
        "foreground": "#FCB1B1"
      }
    },
    {
      "name": "Bracket: 括号[]",
      "scope": [
        "meta.brace.square",
        "punctuation.definition.array"
      ],
      "settings": {
        "foreground": "#FEC771"
      }
    },
    {
      "name": "Punctuation:符号(`'\")",
      "settings": {
        "foreground": "#B7FBFF"
      },
      "scope": [
        "punctuation.definition.string",
        "keyword.operator.comparison.php",
        "keyword.operator.arithmetic.php",
        "punctuation.support.type.property-name",
        "punctuation.separator.key-value.mapping.yaml"
      ]
    },
    {
      "name": "Punctuation:符号(,.;:=)",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator",
        "punctuation.terminator",
        "keyword.operator.assignment"
      ],
      "settings": {
        "foreground": "#F9DE79"
      }
    },
    {
      "name": "Shell_Command: 命令",
      "scope": [
        "entity.name.command",
        "support.function.builtin.shell"
      ],
      "settings": {
        "foreground": "#3DD5E7"
      }
    },
    {
      "name": "Shell_Option: 选项",
      "scope": [
        "constant.other.option",
        "string.unquoted.argument"
      ],
      "settings": {
        "foreground": "#ECFF14"
      }
    },
    {
      "name": "Shell_Variable: 变量调用",
      "scope": [
        "variable.other.normal.shell"
      ],
      "settings": {
        "foreground": "#5AF78E"
      }
    },
    {
      "name": "Shell_Bracket:小括号:$()",
      "scope": [
        "punctuation.definition.evaluation.parens"
      ],
      "settings": {
        "foreground": "#D9E066"
      }
    },
    {
      "name": "Shell_Bracket:大括号:${}",
      "scope": [
        "punctuation.definition.variable.shell"
      ],
      "settings": {
        "foreground": "#F580FF"
      }
    },
    {
      "name": "Applescript: 函数调用",
      "scope": [
        "meta.statement.set.applescript",
        "meta.block.repeat.with.applescript"
      ],
      "settings": {
        "foreground": "#A6F6FF"
      }
    }
  ],
