{
  "name": "Boxy Yesterday",
  "type": "light",
  "semanticTokenColors": {
    "variable.declaration": {},
    "variable.defaultLibrary": {
      "foreground": "#718C00"
    }
  },
  "tokenColors": [
    {
      "name": "Comments: 注释",
      "scope": [
        "comment",
        "commentpunctuation",
        "comment.block.preprocessor",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#8E908C"
      }
    },
    {
      "name": "Keywords: 关键字",
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "support.type",
        "variable.other.rust",
        "entity.name.tag.html",
        "keyword.operator.new.js",
        "entity.name.section.markdown",
        "punctuation.definition.directive.c",
        "punctuation.definition.directive.cpp",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#9c69bd"
      }
    },
    {
      "name": "Keywords Controls: 关键字控制语句",
      "scope": [
        "keyword.control"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#9C69BD"
      }
    },
    {
      "name": "Functions: 函数名",
      "scope": [
        "support.function.go",
        "support.function.lua",
        "entity.name.function.c",
        "entity.name.function.go",
        "entity.name.function.ts",
        "entity.name.function.js",
        "entity.name.function.lua",
        "entity.name.function.java",
        "entity.name.command.shell",
        "entity.name.function.rust",
        "entity.name.function.ruby",
        "entity.name.function.shell",
        "support.function.builtin.go",
        "entity.name.function.python",
        "variable.other.constant.ruby",
        "entity.name.function.call.cpp",
        "support.function.any-method.lua",
        "support.function.builtin.python",
        "meta.function-call.generic.python",
        "entity.name.function.definition.cpp",
        "entity.name.function.handler.applescript",
        "support.function.built-in.command.applescript",
        "support.function.built-in.property.applescript"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#4271ae"
      }
    },
    {
      "name": "Classes: 类名",
      "scope": [
        "support.class",
        "entity.name.type",
        "support.type.python",
        "variable.other.object.java",
        "entity.other.inherited-class",
        "entity.name.scope-resolution.cpp",
        "storage.type.built-in.primitive.c",
        "entity.name.scope-resolution.function.call.cpp",
        "entity.name.scope-resolution.function.definition.cpp"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#C99E00"
      }
    },
    {
      "name": "Numbers: 数字",
      "scope": [
        "constant",
        "constant.numeric",
        "entity.name.tag.yaml",
        "markup.bold.markdown",
        "markup.table.markdown",
        "meta.object.member.js",
        "variable.parameter.js",
        "variable.parameter.cpp",
        "meta.parameter-expansion",
        "variable.language.self.rust",
        "support.function.library.lua",
        "variable.parameter.probably.c",
        "variable.parameter.function.lua",
        "variable.parameter.function.ruby",
        "entity.other.attribute-name.html",
        "markup.inline.raw.string.markdown",
        "variable.language.special.self.python",
        "variable.parameter.handler.applescript",
        "variable.parameter.function-call.python",
        "variable.parameter.function.language.python"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#F5871F"
      }
    },
    {
      "name": "Operators: 运算符",
      "scope": [
        "keyword.operator",
        "entity.name.tag.css",
        "punctuation.definition.markdown",
        "punctuation.definition.string.end.c",
        "fenced_code.block.language.markdown",
        "punctuation.separator.key-value.html",
        "punctuation.separator.table.markdown",
        "punctuation.definition.bold.markdown",
        "punctuation.definition.string.begin.c",
        "punctuation.definition.string.end.cpp",
        "punctuation.definition.table.markdown",
        "punctuation.definition.string.begin.cpp",
        "punctuation.definition.list.begin.markdown",
        "punctuation.definition.quote.begin.markdown",
        "punctuation.section.angle-brackets.end.template.call.cpp",
        "punctuation.section.angle-brackets.begin.template.call.cpp"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#3E999F"
      }
    },
    {
      "name": "Strings: 字符串",
      "scope": [
        "string",
        "constant.character",
        "constant.other.symbol.ruby",
        "storage.modifier.import.java",
        "constant.other.symbol.hashkey.ruby",
        "punctuation.definition.raw.markdown"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#718C00"
      }
    },
    {
      "name": "Punctuation: 分隔符",
      "scope": [
        "source.lua",
        "punctuation",
        "meta.brace.round"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#3E999F"
      }
    },
    {
      "name": "Variable: 变量",
      "scope": [
        "variable.other.lua"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#4D4D4C"
      }
    },
    {
      "name": "Shell Variable: 变量",
      "scope": [
        "meta.argument.shell",
        "string.quoted.double.shell"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#E95678"
      }
    }
  ],
